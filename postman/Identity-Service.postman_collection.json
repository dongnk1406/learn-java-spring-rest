                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"READ_DATA\",\n  \"description\": \"Read access\"\n}"
            },
            "url": "{{baseUrl}}/permissions"
          }
        },
        {
          "name": "Delete permission",
          "request": {
            "auth": {
              "type": "bearer",
